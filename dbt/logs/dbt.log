  create  table "db"."public_silver"."silver_customers__dbt_tmp"
  
  
    as
  
  (
    with src as (
  select * from bronze.customers
)
select
  customer_id,
  company_name,
  country,
  industry,
  company_size,
  signup_date::timestamp as signup_date,

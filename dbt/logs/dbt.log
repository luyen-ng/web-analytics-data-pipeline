  pageviews,
  session_duration_s,
  (bounced=1) as bounced,
  (converted=1) as converted,
  session_start::timestamp as session_start,
  updated_at::timestamp as updated_at,
  date_trunc('day', session_start)::date as session_day
from src
  );
  
